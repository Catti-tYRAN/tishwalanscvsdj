        'snob'     => array('attack' => 30,  'def_inf' => 100, 'def_cav' => 50,  'haul' => 0),
    );
}

// ============================================================
// COMBATE: dofight()
// ============================================================

/**
 * Calcula el resultado del combate entre un ejército atacante y uno defensor.
 *
 * FÓRMULA:
 *   1. poder_ataque = sum(unidades * stats.attack)
 *   2. ratio_caballería = unidades_cav / total_unidades_ataque
 *   3. poder_defensa = sum(unidades * (ratio_inf*def_inf + ratio_cav*def_cav)) * factor_muro
 *   4. factor_muro = 1.037^nivel_muro  (nivel 20 ≈ x2.07)
 *   5. suerte = aleatorio entre -12.5% y +12.5%
 *   6. ataque_modificado = poder_ataque * (1 + suerte)
 *   7. Ganador: quien tiene mayor poder
 *   8. Supervivientes del ganador = original * (ganador / (ganador + perdedor))^1.5
 *   9. El bando perdedor pierde TODAS sus tropas
 *
 * @param array $attackingArmy  Ejército atacante: array('spear' => N, 'sword' => N, ...)
 * @param array $defendingArmy  Ejército defensor: array('spear' => N, 'sword' => N, ...)
 * @param int   $wallLevel      Nivel del muro (0-20)
 * @param float $luck           Suerte forzada (-0.125 a 0.125), null = aleatorio
 *
 * @return array Resultado:
 *   - attacker_wins  (bool)
 *   - luck           (float)  valor de suerte aplicado
 *   - attack_power   (float)  poder de ataque final (con suerte)
 *   - defense_power  (float)  poder de defensa final (con muro)
 *   - wall_factor    (float)  multiplicador del muro
 *   - attacking      array con 'before' y 'after' (tropas antes/después)
 *   - defending      array con 'before' y 'after' (tropas antes/después)
 */
function dofight($attackingArmy, $defendingArmy, $wallLevel = 0, $luck = null) {
    $unitStats    = getUnitStats();
    $units        = getUnitList();
    $cavalryUnits = array('light', 'marcher', 'heavy');

    // --- Normalizar ejércitos ---
    foreach ($units as $unit) {
        $attackingArmy[$unit] = isset($attackingArmy[$unit]) ? max(0, (int)$attackingArmy[$unit]) : 0;
        $defendingArmy[$unit] = isset($defendingArmy[$unit]) ? max(0, (int)$defendingArmy[$unit]) : 0;
    }

    // --- Calcular poder de ataque y ratio caballería/infantería ---
    $totalAttackPower  = 0;
    $totalAttackUnits  = 0;
    $totalCavalryUnits = 0;

    foreach ($units as $unit) {
        $count = $attackingArmy[$unit];
        $totalAttackPower  += $count * $unitStats[$unit]['attack'];
        $totalAttackUnits  += $count;
        if (in_array($unit, $cavalryUnits)) {
            $totalCavalryUnits += $count;
        }
    }

    $cavalryRatio  = ($totalAttackUnits > 0) ? ($totalCavalryUnits / $totalAttackUnits) : 0.0;
    $infantryRatio = 1.0 - $cavalryRatio;

    // --- Factor de muro: 1.037^nivel (nivel 20 ≈ ×2.07, equivalente al original TW) ---
    $wallLevel   = max(0, min(20, (int)$wallLevel));
    $wallFactor  = pow(1.037, $wallLevel);

    // --- Calcular poder de defensa (con muro) ---
    $totalDefensePower = 0.0;
    foreach ($units as $unit) {
        $count    = $defendingArmy[$unit];
        $defValue = ($infantryRatio * $unitStats[$unit]['def_inf'])
                  + ($cavalryRatio  * $unitStats[$unit]['def_cav']);
        $totalDefensePower += $count * $defValue;
    }
    $totalDefensePower *= $wallFactor;

    // --- Suerte: -12.5% a +12.5% ---
    if ($luck === null) {
        $luck = (mt_rand(0, 250) - 125) / 1000.0;
    }
    $modifiedAttack = $totalAttackPower * (1.0 + $luck);

    // --- Determinar ganador y calcular supervivientes ---
    //
    // Fórmula de supervivientes del bando ganador:
    //   fraction = (poder_ganador / (poder_ganador + poder_perdedor)) ^ 1.5
    //
    // El exponent 1.5 produce resultados realistas:
    //   - Pelea pareja (1:1)  → ~35% del ganador sobrevive
    //   - Ventaja doble (2:1) → ~54% sobrevive
    //   - Ventaja cuádruple   → ~71% sobrevive
    //
    // El bando PERDEDOR pierde el 100% de sus tropas.
    //

    $attackerWins  = ($modifiedAttack >= $totalDefensePower);
    $attackingAfter = array();
    $defendingAfter = array();

    if ($modifiedAttack <= 0 && $totalDefensePower <= 0) {
        // Aldea vacía atacada sin tropas → sin combate
        $attackingAfter = $attackingArmy;
        $defendingAfter = $defendingArmy;

    } elseif ($attackerWins) {
        if ($totalDefensePower <= 0) {
            $survivorFraction = 1.0; // Sin defensores → todos los atacantes sobreviven
        } else {
            $survivorFraction = pow(
                $modifiedAttack / ($modifiedAttack + $totalDefensePower),
                1.5
            );
        }
        foreach ($units as $unit) {
            $attackingAfter[$unit] = (int)floor($attackingArmy[$unit] * $survivorFraction);
            $defendingAfter[$unit] = 0;
        }

    } else {
        // Defensor gana
        if ($modifiedAttack <= 0) {
            $survivorFraction = 1.0;
        } else {
            $survivorFraction = pow(
                $totalDefensePower / ($modifiedAttack + $totalDefensePower),
                1.5
            );
        }
        foreach ($units as $unit) {
            $attackingAfter[$unit] = 0;
            $defendingAfter[$unit] = (int)floor($defendingArmy[$unit] * $survivorFraction);
        }
    }

    return array(
        'attacker_wins'  => $attackerWins,
        'luck'           => $luck,
        'attack_power'   => $modifiedAttack,
        'defense_power'  => $totalDefensePower,
        'wall_factor'    => $wallFactor,
        'attacking'      => array('before' => $attackingArmy, 'after' => $attackingAfter),
        'defending'      => array('before' => $defendingArmy, 'after' => $defendingAfter),
    );
}

// ============================================================
// SAQUEO: calculateLoot()
// ============================================================

/**
 * Calcula los recursos que saquean las tropas atacantes supervivientes.
 *
 * LÓGICA:
 *   1. Calcular capacidad total de carga de las tropas supervivientes
 *   2. Restar recursos protegidos por el escondite (building_hide)
 *      - Fórmula: nivel_escondite * 50 unidades protegidas por recurso
 *      - Nivel 10 → 500 de cada recurso protegido
 *   3. Distribuir la carga proporcionalmente entre madera, piedra, hierro
 *
 * @param array $survivingArmy  Tropas supervivientes del atacante
 * @param array $village        Datos de la aldea defensora (res_wood, res_stone, res_iron, building_hide)
 *
 * @return array
 *   - wood, stone, iron  cantidad de cada recurso saqueado
 *   - capacity           capacidad total de carga del ejército
 *   - used               recursos totales saqueados
 */
function calculateLoot($survivingArmy, $village) {
    $unitStats = getUnitStats();

    // Calcular capacidad total de carga
    $totalCapacity = 0;
    foreach ($unitStats as $unit => $stats) {
        $count = isset($survivingArmy[$unit]) ? max(0, (int)$survivingArmy[$unit]) : 0;
        $totalCapacity += $count * $stats['haul'];
    }

    if ($totalCapacity <= 0) {
        return array('wood' => 0, 'stone' => 0, 'iron' => 0, 'capacity' => 0, 'used' => 0);
    }

    // Recursos disponibles en la aldea
    $wood  = max(0.0, (float)(isset($village['res_wood'])  ? $village['res_wood']  : 0));
    $stone = max(0.0, (float)(isset($village['res_stone']) ? $village['res_stone'] : 0));
    $iron  = max(0.0, (float)(isset($village['res_iron'])  ? $village['res_iron']  : 0));

    // Protección del escondite: nivel * 50 unidades por recurso
    $hideLevel        = max(0, (int)(isset($village['building_hide']) ? $village['building_hide'] : 0));
    $hiddenPerRes     = $hideLevel * 50;

    $availableWood  = max(0.0, $wood  - $hiddenPerRes);
    $availableStone = max(0.0, $stone - $hiddenPerRes);
    $availableIron  = max(0.0, $iron  - $hiddenPerRes);

    $totalAvailable = $availableWood + $availableStone + $availableIron;

    if ($totalAvailable <= 0) {
        return array('wood' => 0, 'stone' => 0, 'iron' => 0,
                     'capacity' => $totalCapacity, 'used' => 0);
    }

    // Distribuir proporcionalmente
    if ($totalAvailable <= $totalCapacity) {
        // Llevamos todo lo que hay disponible
        $lootWood  = (int)floor($availableWood);
        $lootStone = (int)floor($availableStone);
        $lootIron  = (int)floor($availableIron);
    } else {
        // Solo alcanza para una fracción → distribuir proporcionalmente
        $ratio     = $totalCapacity / $totalAvailable;
        $lootWood  = (int)floor($availableWood  * $ratio);
        $lootStone = (int)floor($availableStone * $ratio);
        $lootIron  = (int)floor($availableIron  * $ratio);
    }

    $lootUsed = $lootWood + $lootStone + $lootIron;

    return array(
        'wood'     => $lootWood,
        'stone'    => $lootStone,
        'iron'     => $lootIron,
        'capacity' => $totalCapacity,
        'used'     => $lootUsed,
    );
}

