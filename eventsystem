/**
 * Lista de unidades del juego (orden consistente en todo el sistema)
 */
function getUnitList() {
    return array('spear', 'sword', 'axe', 'archer', 'spy', 'light',
                 'marcher', 'heavy', 'ram', 'catapult', 'knight', 'snob');
}

/**
