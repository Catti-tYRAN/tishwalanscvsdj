        'archer'   => array('attack' => 15,  'def_inf' => 50,  'def_cav' => 40,  'haul' => 10),
        'spy'      => array('attack' => 0,   'def_inf' => 2,   'def_cav' => 1,   'haul' => 0),
        'light'    => array('attack' => 130, 'def_inf' => 30,  'def_cav' => 80,  'haul' => 80),
        'marcher'  => array('attack' => 120, 'def_inf' => 40,  'def_cav' => 30,  'haul' => 50),
        'heavy'    => array('attack' => 150, 'def_inf' => 100, 'def_cav' => 50,  'haul' => 50),
        'ram'      => array('attack' => 2,   'def_inf' => 20,  'def_cav' => 5,   'haul' => 0),
        'catapult' => array('attack' => 100, 'def_inf' => 50,  'def_cav' => 50,  'haul' => 0),
