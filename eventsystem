 *   def_inf    = defensa contra infantería
 *   def_cav    = defensa contra caballería
 *   haul       = capacidad de carga (recursos)
 *
 * Basado en los valores estándar de Tribal Wars que TWLan replica.
 */
function getUnitStats() {
    return array(
        'spear'    => array('attack' => 10,  'def_inf' => 15,  'def_cav' => 45,  'haul' => 25),
        'sword'    => array('attack' => 25,  'def_inf' => 50,  'def_cav' => 25,  'haul' => 15),
