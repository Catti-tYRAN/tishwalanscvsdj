/**
 * Procesa un evento de construcción.
 */
function handleBuildEvent($db, $event) {
    try {
        $db->beginTransaction();

        $stmt = $db->prepare("SELECT * FROM world_village WHERE id_village = ?");
        $stmt->execute(array($event['id_village_to']));
        $village = $stmt->fetch(PDO::FETCH_ASSOC);

        if (!$village) {
            deleteEvent($db, $event['id_event']);
            $db->commit();
            return;
        }

        $building = 'building_' . $event['building'];
        $destroy  = (bool)$event['destroy'];
        $current  = isset($village[$building]) ? (int)$village[$building] : 0;
        $newLevel = $destroy ? max(0, $current - 1) : $current + 1;

        $db->prepare("UPDATE world_village SET `{$building}` = ? WHERE id_village = ?")
           ->execute(array($newLevel, $event['id_village_to']));

        $db->prepare("DELETE FROM world_event_build WHERE id_event = ?")
           ->execute(array($event['id_event']));
        deleteEvent($db, $event['id_event']);

        $db->commit();
        echo "[BUILD] Aldea {$event['id_village_to']}: {$event['building']} → nivel {$newLevel}\n";

    } catch (Exception $e) {
        $db->rollBack();
        echo "[ERROR] handleBuildEvent: " . $e->getMessage() . "\n";
    }
}

/**
 * Procesa un evento de entrenamiento.
 */
function handleTrainEvent($db, $event) {
    try {
        $db->beginTransaction();

        $unit   = $event['unit'];
        $amount = (int)$event['amount'];

        $stmt = $db->prepare("
            SELECT id_army FROM world_unit
            WHERE id_village_from = ? AND id_village_to = ?
        ");
        $stmt->execute(array($event['id_village_to'], $event['id_village_to']));
        $army = $stmt->fetch(PDO::FETCH_ASSOC);

        if ($army) {
            $db->prepare("UPDATE world_unit SET `unit_{$unit}` = `unit_{$unit}` + ? WHERE id_army = ?")
               ->execute(array($amount, $army['id_army']));
        } else {
            $db->prepare("INSERT INTO world_unit (id_village_from, id_village_to, `unit_{$unit}`) VALUES (?, ?, ?)")
               ->execute(array($event['id_village_to'], $event['id_village_to'], $amount));
        }

        $db->prepare("DELETE FROM world_event_train WHERE id_event = ?")
           ->execute(array($event['id_event']));
        deleteEvent($db, $event['id_event']);

        $db->commit();
        echo "[TRAIN] Aldea {$event['id_village_to']}: +{$amount} {$unit}\n";

    } catch (Exception $e) {
        $db->rollBack();
        echo "[ERROR] handleTrainEvent: " . $e->getMessage() . "\n";
    }
}

/**
 * Procesa un evento de investigación.
 */
function handleResearchEvent($db, $event) {
    try {
        $db->beginTransaction();

        $stmt = $db->prepare("SELECT * FROM world_event_research WHERE id_event = ?");
        $stmt->execute(array($event['id_event']));
        $research = $stmt->fetch(PDO::FETCH_ASSOC);

        if ($research) {
            $unit  = $research['unit'];
            $field = 'research_' . $unit;
            $db->prepare("UPDATE world_village SET `{$field}` = 1 WHERE id_village = ?")
               ->execute(array($event['id_village_to']));

            $db->prepare("DELETE FROM world_event_research WHERE id_event = ?")
               ->execute(array($event['id_event']));
        }

        deleteEvent($db, $event['id_event']);
        $db->commit();

        if ($research) {
            echo "[RESEARCH] Aldea {$event['id_village_to']}: {$research['unit']} investigado\n";
        }

    } catch (Exception $e) {
        $db->rollBack();
        echo "[ERROR] handleResearchEvent: " . $e->getMessage() . "\n";
    }
}

/**
 * Procesa un evento de ejército.
 *
 * movement_type:
 *   0 = Ataque   → ejecuta combate real, crea retorno con supervivientes
 *   2 = Apoyo    → agrega tropas a aldea destino
 *   3 = Retorno  → devuelve tropas a aldea origen + entrega saqueo
 *   4 = Espionaje → crea evento de retorno (sin combate)
 */
function handleArmyEvent($db, $event) {
    try {
        $db->beginTransaction();
		
		$eventType    = (int)$event['event_type'];
        $movementType = (int)$event['movement_type'];
        $fromVillage  = (int)$event['id_village_from'];
        $toVillage    = (int)$event['id_village_to'];

        $eventData = !empty($event['data']) ? json_decode($event['data'], true) : array();
        $units     = getUnitList();

        switch ($movementType) {
	
	
            // ----------------------------------------
            case 0: // ATAQUE — Combate real
            // ----------------------------------------

                // 1. Cargar tropas defensoras de la aldea destino
                $stmtDef = $db->prepare("
                    SELECT * FROM world_unit
                    WHERE id_village_from = ? AND id_village_to = ?
                ");
                $stmtDef->execute(array($toVillage, $toVillage));
                $defenderRow = $stmtDef->fetch(PDO::FETCH_ASSOC);

                // 2. Cargar datos de la aldea defensora (muro, escondite, recursos)
                $stmtVil = $db->prepare("SELECT * FROM world_village WHERE id_village = ?");
                $stmtVil->execute(array($toVillage));
                $defenderVillage = $stmtVil->fetch(PDO::FETCH_ASSOC);

                // 3. Armar arrays de ejércitos
                $attackingArmy = array();
                $defendingArmy = array();
                foreach ($units as $unit) {
                    $attackingArmy[$unit] = isset($event['unit_' . $unit])
                        ? (int)$event['unit_' . $unit] : 0;
                    $defendingArmy[$unit] = ($defenderRow && isset($defenderRow['unit_' . $unit]))
                        ? (int)$defenderRow['unit_' . $unit] : 0;
                }

                $wallLevel = $defenderVillage ? (int)(isset($defenderVillage['building_wall']) ? $defenderVillage['building_wall'] : 0) : 0;

                // 4. ¡Ejecutar combate!
                $fightResult = dofight($attackingArmy, $defendingArmy, $wallLevel);

                // 5. Actualizar tropas defensoras supervivientes en world_unit
                if ($defenderRow) {
                    $sets   = array();
                    $params = array();
                    foreach ($units as $unit) {
                        $sets[]   = "`unit_{$unit}` = ?";
                        $params[] = $fightResult['defending']['after'][$unit];
                    }
                    $params[] = $defenderRow['id_army'];
                    $db->prepare("UPDATE world_unit SET " . implode(', ', $sets) . " WHERE id_army = ?")
                       ->execute($params);
                }
if ($eventType == 3) {
    $movementType = 3; // forzamos el case de retorno
			}
                // 6. Calcular y aplicar saqueo si el atacante ganó
                $lootData = array();
                if ($fightResult['attacker_wins'] && $defenderVillage) {
                    $loot = calculateLoot($fightResult['attacking']['after'], $defenderVillage);

                    if ($loot['used'] > 0) {
                        // Restar recursos de la aldea defensora
                        $db->prepare("
                            UPDATE world_village
                            SET res_wood  = GREATEST(0, res_wood  - ?),
                                res_stone = GREATEST(0, res_stone - ?),
                                res_iron  = GREATEST(0, res_iron  - ?)
                            WHERE id_village = ?
                        ")->execute(array(
                            $loot['wood'],
                            $loot['stone'],
                            $loot['iron'],
                            $toVillage
                        ));

                        $lootData = array(
                            'wood'     => $loot['wood'],
                            'stone'    => $loot['stone'],
                            'iron'     => $loot['iron'],
                            'capacity' => $loot['capacity'],
                            'used'     => $loot['used'],
                        );

                        echo "[LOOT] Aldea {$fromVillage} saquea {$toVillage}: " .
                             "madera={$loot['wood']} piedra={$loot['stone']} hierro={$loot['iron']}\n";
                    }
                }

                // 7. Log del resultado del combate
                $winner   = $fightResult['attacker_wins'] ? "ATACANTE GANA" : "DEFENSOR GANA";
                $luckPct  = round($fightResult['luck'] * 100, 1);
                $atkPow   = round($fightResult['attack_power']);
                $defPow   = round($fightResult['defense_power']);
                echo "[FIGHT] {$fromVillage} → {$toVillage}: ATK={$atkPow} vs DEF={$defPow} " .
                     "[{$winner}] (suerte: {$luckPct}%, muro: nivel {$wallLevel})\n";

                // 8. Armar eventData del retorno (saqueo + info del combate)
                $returnData = array();
                if (!empty($lootData)) {
                    $returnData['loot'] = $lootData;
                }
                $returnData['fight'] = array(
                    'attacker_wins' => $fightResult['attacker_wins'],
                    'luck'          => $fightResult['luck'],
                    'wall_level'    => $wallLevel,
                );

                // 9. Crear evento de retorno con tropas SUPERVIVIENTES (no las originales)
                handleReturn($db, $event, $returnData, $fightResult['attacking']['after']);
                break;

            // ----------------------------------------
            case 2: // APOYO — Agregar tropas a aldea destino
            // ----------------------------------------
                addUnitsToVillage($db, $event, $toVillage);
                break;

            // ----------------------------------------
            case 3: // RETORNO — Devolver tropas y saqueo a aldea origen
            // ----------------------------------------
                addUnitsToVillage($db, $event, $fromVillage);

                // Entregar recursos saqueados a la aldea de origen
                if (!empty($eventData['loot'])) {
                    $loot = $eventData['loot'];
                    $db->prepare("
                        UPDATE world_village
                        SET res_wood  = res_wood  + ?,
                            res_stone = res_stone + ?,
                            res_iron  = res_iron  + ?
                        WHERE id_village = ?
                    ")->execute(array(
                        (int)(isset($loot['wood'])  ? $loot['wood']  : 0),
                        (int)(isset($loot['stone']) ? $loot['stone'] : 0),
                        (int)(isset($loot['iron'])  ? $loot['iron']  : 0),
                        $fromVillage
                    ));

                    echo "[RETURN] Aldea {$fromVillage}: Recursos recibidos: " .
                         "madera={$loot['wood']} piedra={$loot['stone']} hierro={$loot['iron']}\n";
                }
                break;

            // ----------------------------------------
            case 4: // ESPIONAJE — Crear evento de retorno sin combate
            // ----------------------------------------
                handleReturn($db, $event, $eventData);
                break;

            default:
                echo "[WARN] Tipo de movimiento desconocido: {$movementType}\n";
        }

        $db->prepare("DELETE FROM world_event_army WHERE id_event = ?")
           ->execute(array($event['id_event']));
        deleteEvent($db, $event['id_event']);
        $db->commit();

    } catch (Exception $e) {
        $db->rollBack();
        echo "[ERROR] handleArmyEvent: " . $e->getMessage() . "\n";
    }
}

/**
 * Agrega unidades de un evento a una aldea en world_unit.
 *
 * Usado por: apoyo (case 2) y retorno (case 3).
 * Las tropas están en los campos unit_spear, unit_sword, etc. del $event.
 */
function addUnitsToVillage($db, $event, $idVillage) {
    $units = getUnitList();

    $stmt = $db->prepare("
        SELECT id_army FROM world_unit
        WHERE id_village_from = ? AND id_village_to = ?
    ");
    $stmt->execute(array($idVillage, $idVillage));
    $army = $stmt->fetch(PDO::FETCH_ASSOC);

    $totalUnits = 0;
    foreach ($units as $unit) {
        $field = 'unit_' . $unit;
        $totalUnits += isset($event[$field]) ? (int)$event[$field] : 0;
    }

    if ($totalUnits === 0) {
        echo "[RETURN] Aldea {$idVillage}: Sin tropas supervivientes\n";
        return;
    }

    if ($army) {
        $sets   = array();
        $params = array();
        foreach ($units as $unit) {
            $field  = 'unit_' . $unit;
            $amount = isset($event[$field]) ? (int)$event[$field] : 0;
            if ($amount > 0) {
                $sets[]   = "`{$field}` = `{$field}` + ?";
                $params[] = $amount;
            }
        }
        if (!empty($sets)) {
            $params[] = $army['id_army'];
            $db->prepare("UPDATE world_unit SET " . implode(', ', $sets) . " WHERE id_army = ?")
               ->execute($params);
        }
        echo "[RETURN] Aldea {$idVillage}: +{$totalUnits} tropas (actualizado)\n";
    } else {
        $cols = array('id_village_from', 'id_village_to');
        $vals = array($idVillage, $idVillage);
        foreach ($units as $unit) {
            $field  = 'unit_' . $unit;
            $cols[] = $field;
            $vals[] = isset($event[$field]) ? (int)$event[$field] : 0;
        }
        $placeholders = implode(', ', array_fill(0, count($vals), '?'));
        $colStr       = '`' . implode('`, `', $cols) . '`';
        $db->prepare("INSERT INTO world_unit ({$colStr}) VALUES ({$placeholders})")
           ->execute($vals);
        echo "[RETURN] Aldea {$idVillage}: +{$totalUnits} tropas (nuevo ejército)\n";
    }
}

/**
 * Crea evento de retorno para tropas atacantes.
 *
 * @param PDO   $db            Conexión a base de datos
 * @param array $event         Evento original (contiene id_village_from, start, finish)
 * @param array $eventData     Datos adicionales: loot, fight info (se guarda en campo 'data')
 * @param array $survivorTroops  Tropas supervivientes reales del combate.
 *                               Si es null, usa las tropas del evento original (fallback).
 */
function handleReturn($db, $event, $eventData = array(), $survivorTroops = null) {
    $now        = microtime(true);
    $duration   = $event['finish'] - $event['start'];
    $returnTime = $now + $duration;

    // Crear evento base
    $stmt = $db->prepare("
        INSERT INTO world_event (event_type, finish, start)
        VALUES (3, ?, ?)
    ");
    $stmt->execute(array($returnTime, $now, $event['id_village_from']));
    $newEventId = $db->lastInsertId();

    // Armar INSERT de world_event_army con tropas supervivientes
    $units = getUnitList();
    $cols = array('id_event', 'id_village_from', 'movement_type');
    $vals = array($newEventId, $event['id_village_from'], 0);

    foreach ($units as $unit) {
        $field  = 'unit_' . $unit;
        $cols[] = $field;

        if ($survivorTroops !== null) {
            // Tropas reales post-combate
            $vals[] = isset($survivorTroops[$unit]) ? (int)$survivorTroops[$unit] : 0;
        } else {
            // Fallback: tropas originales del evento (p.ej. espionaje)
            $vals[] = isset($event[$field]) ? (int)$event[$field] : 0;
        }
    }

    $cols[] = 'data';
    $vals[] = !empty($eventData) ? json_encode($eventData) : null;

    $placeholders = implode(', ', array_fill(0, count($vals), '?'));
    $colStr       = '`' . implode('`, `', $cols) . '`';

    $db->prepare("INSERT INTO world_event_army ({$colStr}) VALUES ({$placeholders})")
       ->execute($vals);

    $finishDate = date('Y-m-d H:i:s', (int)$returnTime);
    echo "[ARMY] Evento de retorno #{$newEventId} creado → Aldea {$event['id_village_from']} (llega: {$finishDate})\n";
}

/**
 * Elimina un evento de la tabla base.
 */
function deleteEvent($db, $idEvent) {
    $db->prepare("DELETE FROM world_event WHERE id_event = ?")
       ->execute(array($idEvent));
}

// ============================================================
// HANDLE EVENTS — procesa todos los eventos vencidos
// ============================================================

function handleEvents($db) {
    $now = microtime(true);

    // Construcciones
    $stmt = $db->prepare("
        SELECT e.*, eb.building, eb.destroy
        FROM world_event e
        INNER JOIN world_event_build eb ON eb.id_event = e.id_event
        WHERE e.finish <= ? ORDER BY e.finish ASC
    ");
    $stmt->execute(array($now));
    foreach ($stmt->fetchAll(PDO::FETCH_ASSOC) as $event) {
        handleBuildEvent($db, $event);
    }

    // Entrenamientos
    $stmt = $db->prepare("
        SELECT e.*, et.unit, et.amount, et.decommission
        FROM world_event e
        INNER JOIN world_event_train et ON et.id_event = e.id_event
        WHERE e.finish <= ? ORDER BY e.finish ASC
    ");
    $stmt->execute(array($now));
    foreach ($stmt->fetchAll(PDO::FETCH_ASSOC) as $event) {
        handleTrainEvent($db, $event);
    }

    // Investigaciones
    $stmt = $db->prepare("
        SELECT e.*
        FROM world_event e
        INNER JOIN world_event_research er ON er.id_event = e.id_event
        WHERE e.finish <= ? ORDER BY e.finish ASC
    ");
    $stmt->execute(array($now));
    foreach ($stmt->fetchAll(PDO::FETCH_ASSOC) as $event) {
        handleResearchEvent($db, $event);
    }

    // Ejércitos
    $stmt = $db->prepare("
        SELECT e.*, ea.*
        FROM world_event e
        INNER JOIN world_event_army ea ON ea.id_event = e.id_event
        WHERE e.finish <= ? ORDER BY e.finish ASC
    ");
    $stmt->execute(array($now));
    foreach ($stmt->fetchAll(PDO::FETCH_ASSOC) as $event) {
        handleArmyEvent($db, $event);
    }
}

// ============================================================
// UPDATE RANKS
// ============================================================

function updateRanks($db) {
    try {
        $db->exec("
            UPDATE world_user SET
                cached_points = (
                    SELECT COALESCE(SUM(points), 0)
                    FROM world_village
                    WHERE id_user_owner = world_user.id_user
                ),
                cached_villages = (
                    SELECT COUNT(*)
                    FROM world_village
                    WHERE id_user_owner = world_user.id_user
                )
        ");
        echo "[RANKS] Rankings actualizados\n";
    } catch (Exception $e) {
        echo "[ERROR] updateRanks: " . $e->getMessage() . "\n";
    }
}

// ============================================================
// LOOP PRINCIPAL
// ============================================================

// En handleEvents(), antes de procesar:
$lock = $db->query("SELECT GET_LOCK('twlan_eventsystem', 0)")->fetchColumn();
if (!$lock) return; // El original ya está procesando, saltamos este tick

// ... todo el procesamiento normal ...

$db->query("SELECT RELEASE_LOCK('twlan_eventsystem')");

$tick = 0;

while (true) {
    $tick++;

    try {
        handleEvents($db);

        if ($tick % RANKS_EVERY_TICKS === 0) {
            updateRanks($db);
            $tick = 0;
        }
    } catch (Exception $e) {
        echo "[ERROR] Loop: " . $e->getMessage() . "\n";
        try {
            \TWLan\ORM\Lemon::disconnect();
            $db = \TWLan\ORM\Lemon::db();
        } catch (Exception $e2) {
            echo "[ERROR] Reconexión fallida: " . $e2->getMessage() . "\n";
        }
    }

    usleep(TICK_SLEEP_MS);
}